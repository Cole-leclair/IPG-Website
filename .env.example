# Environment variables for ipg.team — reference only, no real values here.
#
# Production values are set in the Netlify UI (Site settings -> Environment
# variables). For local testing, copy this file to `.env` (git-ignored) and
# fill it in; `netlify dev` reads it automatically.

# ---- Bindly lead webhook (existing — submission-created.js) ----
# Write-only endpoint that receives website form leads.
BINDLY_API_URL=https://bindly.to/api/webhook/leads
BINDLY_API_KEY=

# ---- Bindly PORTAL READ API (portal Phase 2 — utils/bindly.js) ----
# A SEPARATE surface from the lead webhook above, with its own READ-SCOPED key.
# Contract: "Bindly Portal Read-API v1" (2026-07-11).
BINDLY_READ_API_URL=https://bindly.to/api/portal/v1
# Read-scoped portal key from Bindly. TREAT AS A SECRET — server-side only,
# never in portal.js or the repo. This is NOT the write-only BINDLY_API_KEY
# above; keep them distinct so a leak of one never exposes the other. Bindly
# issues two of these (production + staging) — on Netlify, set a DIFFERENT
# value per deploy context (production vs. deploy-preview) so a staging leak
# never forces a production rotation.
BINDLY_PORTAL_API_KEY=

# ---- Clerk auth (portal Phase 1 — utils/auth.js) ----
CLERK_JWKS_URL=
# Secret key (sk_...) for the Clerk Backend API — used to CREATE/manage users
# (tools/create-portal-user.js + the staff/admin tab: portal-admin-users.js).
# TREAT AS A SECRET. Not needed for login verification (that uses the JWKS above).
CLERK_SECRET_KEY=
# Where an invited person lands to finish setup (set their password natively on
# ipg.team, not Clerk's hosted page). Production: https://ipg.team/portal/
# Local (netlify dev): http://localhost:8888/portal/
PORTAL_INVITE_REDIRECT_URL=https://ipg.team/portal/

# ---- Portal database (portal Phase 1 — Neon/Postgres) ----
# Connection string from the Neon dashboard. TREAT AS A SECRET — never
# commit the real value. Run portal/db/schema.sql once to create tables.
DATABASE_URL=

# ---- Google reviews (reviews.js) ----
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# ---- Local development ONLY ----
# Skips portal auth and trusts x-dev-client / x-dev-type headers. Ignored on
# production deploys (utils/auth.js checks Netlify's CONTEXT), but never set
# it on a deployed environment anyway.
# PORTAL_DEV_BYPASS=1
